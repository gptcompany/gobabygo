#!/usr/bin/env bash
set -euo pipefail

WS_HOST="${MESH_WS_HOST:-sam@192.168.1.111}"
WS_REPO_BASE="${MESH_WS_REPO_BASE:-/media/sam/1TB}"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'EOF'
Usage:
  ./scripts/ws                # ssh on WS
  ./scripts/ws <repo-name>    # ssh on WS and cd into ${MESH_WS_REPO_BASE}/<repo-name>

Env:
  MESH_WS_HOST       default: sam@192.168.1.111
  MESH_WS_REPO_BASE  default: /media/sam/1TB
EOF
  exit 0
fi

if [[ -z "${1:-}" ]]; then
  exec ssh "$WS_HOST"
fi

repo="$1"
target_dir="${WS_REPO_BASE}/${repo}"
exec ssh -t "$WS_HOST" "if [[ -d '$target_dir' ]]; then cd '$target_dir'; else echo '[ws] missing repo: $target_dir'; cd '$WS_REPO_BASE'; fi; exec \$SHELL -l"
