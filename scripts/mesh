#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ENV_FILE="${MESH_ENV_FILE:-$HOME/.mesh/.env.mesh}"
FALLBACK_EXPORTS="${HOME}/.mesh/router.env"
WS_REPO_BASE="${MESH_WS_REPO_BASE:-/media/sam/1TB}"
PIPELINE_TEMPLATE="${MESH_PIPELINE_TEMPLATE:-speckit}"
MESH_UI_FORWARD_HOST="${MESH_UI_FORWARD_HOST-sam@192.168.1.112}"
MESH_UI_FORWARD_REPO="${MESH_UI_FORWARD_REPO-/Users/sam/gobabygo}"
MESH_ENV_SOURCES=(
  "/etc/mesh-worker/mesh-session-claude-work.env"
  "/etc/mesh-worker/mesh-session-codex-work.env"
  "/etc/mesh-worker/mesh-worker-claude-work.env"
  "/etc/mesh-worker/mesh-worker-codex-work.env"
  "/etc/mesh-worker/mesh-worker-gemini-work.env"
  "${FALLBACK_EXPORTS}"
  "${ENV_FILE}"
)

detect_python() {
  if command -v python3 >/dev/null 2>&1; then
    echo "python3"
    return 0
  fi
  if command -v python >/dev/null 2>&1; then
    echo "python"
    return 0
  fi
  echo "Error: python3/python not found in PATH" >&2
  return 127
}

detect_uv() {
  if command -v uv >/dev/null 2>&1; then
    command -v uv
    return 0
  fi
  if [[ -x "$HOME/.local/bin/uv" ]]; then
    echo "$HOME/.local/bin/uv"
    return 0
  fi
  return 1
}

run_meshctl() {
  ensure_router_env

  local use_dotenvx=0
  if [[ -z "${MESH_ROUTER_URL:-}" || -z "${MESH_AUTH_TOKEN:-}" ]]; then
    use_dotenvx=1
  fi

  # Prefer uv-managed environment when available.
  if command -v uv >/dev/null 2>&1 && [[ -f "$REPO_ROOT/pyproject.toml" ]]; then
    if [[ "$use_dotenvx" == "1" ]] && command -v dotenvx >/dev/null 2>&1 && [[ -f "$ENV_FILE" ]]; then
      (cd "$REPO_ROOT" && exec dotenvx run -f "$ENV_FILE" -- uv run -- python -m src.meshctl "$@")
    elif [[ -f "$FALLBACK_EXPORTS" ]]; then
      # shellcheck source=/dev/null
      source "$FALLBACK_EXPORTS"
      (cd "$REPO_ROOT" && exec uv run -- python -m src.meshctl "$@")
    else
      (cd "$REPO_ROOT" && exec uv run -- python -m src.meshctl "$@")
    fi
  fi

  py_bin="$(detect_python)" || exit $?
  if [[ "$use_dotenvx" == "1" ]] && command -v dotenvx >/dev/null 2>&1 && [[ -f "$ENV_FILE" ]]; then
    (cd "$REPO_ROOT" && exec dotenvx run -f "$ENV_FILE" -- "$py_bin" -m src.meshctl "$@")
  elif [[ -f "$FALLBACK_EXPORTS" ]]; then
    # shellcheck source=/dev/null
    source "$FALLBACK_EXPORTS"
    (cd "$REPO_ROOT" && exec "$py_bin" -m src.meshctl "$@")
  else
    (cd "$REPO_ROOT" && exec "$py_bin" -m src.meshctl "$@")
  fi
}

extract_kv() {
  local file="$1" key="$2"
  [[ -r "$file" ]] || return 1
  awk -F= -v key="$key" '
    $0 ~ "^[[:space:]]*(export[[:space:]]+)?"key"=" {
      line = $0
      sub(/^[[:space:]]*(export[[:space:]]+)?/, "", line)
      sub(/^[^=]*=/, "", line)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
      gsub(/^["'"'"']|["'"'"']$/, "", line)
      print line
      exit 0
    }
  ' "$file"
}

persist_router_env_if_possible() {
  [[ -n "${MESH_ROUTER_URL:-}" ]] || return 0
  [[ -n "${MESH_AUTH_TOKEN:-}" ]] || return 0

  mkdir -p "$(dirname "$FALLBACK_EXPORTS")" 2>/dev/null || return 0
  touch "$FALLBACK_EXPORTS" 2>/dev/null || return 0
  cat >"$FALLBACK_EXPORTS" <<EOF
export MESH_ROUTER_URL=${MESH_ROUTER_URL}
export MESH_AUTH_TOKEN=${MESH_AUTH_TOKEN}
EOF
}

ensure_router_env() {
  # Keep explicit shell env as highest priority.
  if [[ -n "${MESH_ROUTER_URL:-}" && -n "${MESH_AUTH_TOKEN:-}" ]]; then
    return 0
  fi

  local src router token

  # Discover values from known env files.
  for src in "${MESH_ENV_SOURCES[@]}"; do
    [[ -r "$src" ]] || continue

    if [[ -z "${MESH_ROUTER_URL:-}" ]]; then
      router="$(extract_kv "$src" "MESH_ROUTER_URL" || true)"
      [[ -n "$router" ]] && export MESH_ROUTER_URL="$router"
    fi

    if [[ -z "${MESH_AUTH_TOKEN:-}" ]]; then
      token="$(extract_kv "$src" "MESH_AUTH_TOKEN" || true)"
      [[ -n "$token" ]] && export MESH_AUTH_TOKEN="$token"
    fi

    if [[ -n "${MESH_ROUTER_URL:-}" && -n "${MESH_AUTH_TOKEN:-}" ]]; then
      break
    fi
  done

  # WS-friendly default router address if nothing discovered.
  if [[ -z "${MESH_ROUTER_URL:-}" && -d "/etc/mesh-worker" ]]; then
    export MESH_ROUTER_URL="http://192.168.1.100:8780"
  fi

  persist_router_env_if_possible
}

usage() {
  cat <<'EOF'
Usage:
  ./scripts/mesh status
  ./scripts/mesh thread [thread-name]
  ./scripts/mesh bootstrap
  ./scripts/mesh deploy
  ./scripts/mesh ui [repo-name|repo-path] [--single-tab] [--max-panes-per-tab N]
  ./scripts/mesh start [feature text]
  ./scripts/mesh new [feature text]
  ./scripts/mesh run <phase>
  ./scripts/mesh run <repo-name|repo-path> <phase>

Env:
  MESH_PIPELINE_TEMPLATE   default: speckit

Examples:
  ./scripts/mesh status
  ./scripts/mesh bootstrap
  ./scripts/mesh deploy
  ./scripts/mesh ui rektaslug
  ./scripts/mesh ui /media/sam/1TB/rektaslug --single-tab
  ./scripts/mesh start
  ./scripts/mesh start "checkout hardening"
  ./scripts/mesh new "spec 017"
  ./scripts/mesh run 016
  ./scripts/mesh run rektslug 016
  ./scripts/mesh run /media/sam/1TB/rektslug 016
  ./scripts/mesh thread
  ./scripts/mesh thread rektslug-spec-016
EOF
}

resolve_repo_path_and_name() {
  # Args:
  #   $1: repo input (name or path)
  # Sets globals:
  #   RESOLVED_REPO_PATH
  #   RESOLVED_REPO_NAME
  local repo_input="$1"
  local repo_path=""
  local repo_name=""

  # Existing dir (absolute or relative) => use as-is
  if [[ -d "$repo_input" ]]; then
    repo_path="$(cd "$repo_input" && pwd -P)"
    repo_name="$(basename "$repo_path")"
  # Path-like token (contains "/") => normalize under current dir
  elif [[ "$repo_input" == *"/"* ]]; then
    repo_path="$(cd "$(dirname "$repo_input")" && pwd -P)/$(basename "$repo_input")"
    repo_name="$(basename "$repo_path")"
  else
    # Pure repo name => resolve under WS_REPO_BASE (legacy behavior)
    repo_name="$repo_input"
    repo_path="${WS_REPO_BASE}/${repo_name}"
  fi

  RESOLVED_REPO_PATH="$repo_path"
  RESOLVED_REPO_NAME="$repo_name"
}

slugify() {
  local text="${1:-}"
  text="$(printf '%s' "$text" | tr '[:upper:]' '[:lower:]')"
  text="$(printf '%s' "$text" | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"
  if [[ -z "$text" ]]; then
    text="work"
  fi
  printf '%s' "$text"
}

gen_feature_label() {
  # Dynamic label for ad-hoc starts without explicit feature text.
  printf 'run-%s-%04d' "$(date +%Y%m%d-%H%M%S)" "$RANDOM"
}

load_router_env() {
  ensure_router_env
}

latest_thread_for_repo() {
  local repo_name="${1:-}"
  load_router_env
  local py_bin
  py_bin="$(detect_python)" || return $?
  "$py_bin" - "$repo_name" <<'PY'
import json
import os
import sys
from urllib.error import HTTPError, URLError
from urllib.request import Request, urlopen

repo_name = sys.argv[1]
prefix = f"{repo_name}-"
base = os.environ.get("MESH_ROUTER_URL", "http://localhost:8780").rstrip("/")
token = os.environ.get("MESH_AUTH_TOKEN", "")
url = f"{base}/threads?limit=200"

req = Request(url)
if token:
    req.add_header("Authorization", f"Bearer {token}")

try:
    with urlopen(req, timeout=10) as resp:
        data = json.loads(resp.read().decode("utf-8"))
except HTTPError as e:
    print(f"Error: /threads returned {e.code}", file=sys.stderr)
    sys.exit(3)
except URLError as e:
    print(f"Error: cannot connect to mesh router at {base} -- {e}", file=sys.stderr)
    sys.exit(4)

threads = data.get("threads", [])
for thread in threads:
    name = str(thread.get("name") or "")
    if name.startswith(prefix):
        print(name)
        sys.exit(0)

sys.exit(2)
PY
}

cmd="${1:-}"
case "$cmd" in
  status)
    run_meshctl status
    ;;
  thread)
    thread_name="${2:-}"
    if [[ -z "$thread_name" ]]; then
      repo_path="$(pwd -P)"
      repo="$(basename "$repo_path")"
      thread_name="$(latest_thread_for_repo "$repo" || true)"
      if [[ -z "$thread_name" ]]; then
        echo "Error: no thread provided and no recent thread found on router for repo '$repo'." >&2
        echo "Use: mesh start \"<feature>\" or mesh thread <thread-name>" >&2
        exit 1
      fi
    fi
    run_meshctl thread status "$thread_name"
    ;;
  bootstrap)
    ws_host="${MESH_WS_HOST:-sam@192.168.1.111}"
    ws_env_dir="${MESH_WS_ENV_DIR:-/etc/mesh-worker}"
    stop_batch="${MESH_BOOTSTRAP_STOP_BATCH:-0}"
    ssh -tt -o ConnectTimeout=10 "$ws_host" "bash -s" -- "$ws_env_dir" "$stop_batch" <<'EOF'
set -euo pipefail

env_dir="${1:?missing env_dir}"
stop_batch="${2:-0}"

set_kv() {
  local file="$1" key="$2" value="$3"
  local escaped
  escaped="$(printf '%s' "$value" | sed 's/[&|]/\\&/g')"
  if sudo grep -q "^${key}=" "$file"; then
    sudo sed -i "s|^${key}=.*|${key}=${escaped}|" "$file"
  else
    echo "${key}=${value}" | sudo tee -a "$file" >/dev/null
  fi
}

configure_session_worker_env() {
  local file="$1"
  if [[ ! -f "$file" ]]; then
    echo "[WARN] missing env file: $file"
    return 0
  fi
  set_kv "$file" MESH_CLI_COMMAND "ccs {target_account}"
  set_kv "$file" MESH_ALLOWED_ACCOUNTS "*"
  echo "[OK] configured $file"
}

configure_session_worker_env "${env_dir}/mesh-session-claude-work.env"
configure_session_worker_env "${env_dir}/mesh-session-codex-work.env"

sudo systemctl restart mesh-session-worker@mesh-session-claude-work
sudo systemctl restart mesh-session-worker@mesh-session-codex-work

if [[ "$stop_batch" == "1" ]]; then
  sudo systemctl stop mesh-worker@claude-work || true
  sudo systemctl stop mesh-worker@codex-work || true
  sudo systemctl stop mesh-worker@gemini-work || true
  echo "[OK] batch workers stopped"
fi

sudo systemctl is-active --quiet mesh-session-worker@mesh-session-claude-work && echo "[OK] session claude active"
sudo systemctl is-active --quiet mesh-session-worker@mesh-session-codex-work && echo "[OK] session codex active"

echo
echo "Bootstrap complete."
echo "Next:"
echo "  1) create CCS repo profiles once (if missing):"
echo "     ccs auth create claude-<repo>"
echo "     ccs auth create codex-<repo>"
echo "  2) run from repo dir:"
echo "     mesh run <phase>"
EOF
    ;;
  ui)
    ui_args=("${@:2}")
    if [[ "$(uname -s)" != "Darwin" ]]; then
      if [[ -n "${MESH_UI_FORWARD_HOST:-}" ]]; then
        escaped_args=""
        for arg in "${ui_args[@]}"; do
          escaped_args+=" $(printf '%q' "$arg")"
        done
        exec ssh -tt "$MESH_UI_FORWARD_HOST" "cd '$MESH_UI_FORWARD_REPO' && ./scripts/mesh ui${escaped_args}"
      fi
      echo "Error: mesh ui is available only on macOS/iTerm2." >&2
      echo "Set MESH_UI_FORWARD_HOST to auto-forward this command to your Mac operator host." >&2
      exit 2
    fi

    py_bin="$(detect_python)" || exit $?
    ui_script="${REPO_ROOT}/scripts/mesh_iterm_ui.py"
    if [[ ! -f "$ui_script" ]]; then
      echo "Error: missing iTerm UI script at $ui_script" >&2
      exit 1
    fi
    set +e
    "$py_bin" "$ui_script" "${ui_args[@]}"
    ui_rc=$?
    set -e
    if [[ "$ui_rc" -eq 3 ]]; then
      if uv_bin="$(detect_uv)"; then
        exec "$uv_bin" run --with iterm2 -- python "$ui_script" "${ui_args[@]}"
      fi
    fi
    exit "$ui_rc"
    ;;
  deploy)
    ws_host="${MESH_WS_HOST:-sam@192.168.1.111}"
    ws_repo_dir="${MESH_WS_REPO_DIR:-/opt/mesh-router}"
    caller_repo_root="${REPO_ROOT}"
    branch="${MESH_DEPLOY_BRANCH:-master}"
    restart_router="${MESH_DEPLOY_RESTART_ROUTER:-1}"
    restart_batch="${MESH_DEPLOY_RESTART_BATCH:-0}"
    restart_session="${MESH_DEPLOY_RESTART_SESSION:-1}"
    deploy_mode="${MESH_DEPLOY_MODE:-auto}" # auto|remote|local
    deploy_script="$(cat <<'EOF'
set -euo pipefail

repo_dir="${1:?missing repo_dir}"
branch="${2:-master}"
restart_router="${3:-1}"
restart_batch="${4:-0}"
restart_session="${5:-1}"
caller_repo_root="${6:-}"

resolve_repo_dir() {
  local preferred="$1" caller="$2"
  local candidates=(
    "$preferred"
    "$caller"
    "/opt/mesh-router"
    "$HOME/gobabygo"
    "/media/sam/1TB/gobabygo"
  )
  local d
  for d in "${candidates[@]}"; do
    if [[ -d "$d/.git" ]]; then
      printf '%s' "$d"
      return 0
    fi
  done
  return 1
}

resolved_repo="$(resolve_repo_dir "$repo_dir" "$caller_repo_root" || true)"
if [[ -z "$resolved_repo" ]]; then
  echo "Error: repo not found. tried: $repo_dir, $caller_repo_root, /opt/mesh-router, $HOME/gobabygo, /media/sam/1TB/gobabygo"
  exit 2
fi
repo_dir="$resolved_repo"

echo "[deploy] repo=$repo_dir branch=$branch"
cd "$repo_dir"
git fetch origin "$branch"
git pull --ff-only origin "$branch"

if [[ -x "$repo_dir/venv/bin/pip" ]]; then
  "$repo_dir/venv/bin/pip" install -e "$repo_dir" >/dev/null
  echo "[deploy] python deps synced"
fi

has_mesh_tmux=0
if command -v tmux >/dev/null 2>&1; then
  if tmux list-sessions 2>/dev/null | grep -q '^mesh-'; then
    has_mesh_tmux=1
  fi
fi

if [[ "$restart_router" == "1" ]]; then
  if systemctl list-unit-files 2>/dev/null | grep -q '^mesh-router\.service'; then
    sudo systemctl restart mesh-router
    sudo systemctl is-active --quiet mesh-router && echo "[deploy] mesh-router active"
  else
    echo "[deploy] mesh-router.service not found on this host; skipping router restart"
  fi
fi

if [[ "$restart_batch" == "1" ]]; then
  if systemctl list-unit-files 2>/dev/null | grep -q '^mesh-worker@\.service'; then
    sudo systemctl restart mesh-worker@claude-work || true
    sudo systemctl restart mesh-worker@codex-work || true
    sudo systemctl restart mesh-worker@gemini-work || true
  else
    echo "[deploy] mesh-worker@.service not found; skipping batch restart"
  fi
  echo "[deploy] batch workers restarted"
fi

if [[ "$restart_session" == "1" ]]; then
  if [[ "$has_mesh_tmux" == "1" ]]; then
    echo "[deploy] session workers NOT restarted (active/stale mesh tmux sessions detected)"
  else
    if systemctl list-unit-files 2>/dev/null | grep -q '^mesh-session-worker@\.service'; then
      sudo systemctl restart mesh-session-worker@mesh-session-claude-work
      sudo systemctl restart mesh-session-worker@mesh-session-codex-work
      echo "[deploy] session workers restarted"
    else
      echo "[deploy] mesh-session-worker@.service not found; skipping session restart"
    fi
  fi
fi

echo "[deploy] done"
EOF
)"

    run_local_deploy() {
      bash -s -- "$ws_repo_dir" "$branch" "$restart_router" "$restart_batch" "$restart_session" "$caller_repo_root" <<<"$deploy_script"
    }

    run_remote_deploy() {
      ssh -tt -o ConnectTimeout=10 "$ws_host" "bash -s" -- \
        "$ws_repo_dir" "$branch" "$restart_router" "$restart_batch" "$restart_session" "$caller_repo_root" <<<"$deploy_script"
    }

    case "$deploy_mode" in
      local)
        run_local_deploy
        ;;
      remote)
        run_remote_deploy
        ;;
      auto)
        if command -v systemctl >/dev/null 2>&1 && [[ -d /etc/mesh-worker ]]; then
          run_local_deploy
        else
          run_remote_deploy || {
            echo "Error: remote deploy failed. Set MESH_WS_HOST correctly (current: $ws_host)." >&2
            exit 1
          }
        fi
        ;;
      *)
        echo "Error: invalid MESH_DEPLOY_MODE='$deploy_mode' (use auto|remote|local)" >&2
        exit 1
        ;;
    esac
    ;;
  start|new)
    feature="${*:2}"
    if [[ -z "$feature" ]]; then
      feature="$(gen_feature_label)"
    fi

    repo_path="$(pwd -P)"
    repo="$(basename "$repo_path")"
    feature_slug="$(slugify "$feature")"
    ts="$(date +%Y%m%d-%H%M%S)"
    thread_name="${repo}-${feature_slug}-${ts}"

    run_meshctl pipeline create \
      --template "$PIPELINE_TEMPLATE" \
      --thread-name "$thread_name" \
      --repo "$repo_path" \
      --project "$repo" \
      --feature "$feature" \
      --phase "" \
      --account-scope repo
    echo "Started thread: $thread_name"
    ;;
  run)
    input_a="${2:-}"
    input_b="${3:-}"

    # Dynamic mode: mesh run <phase>
    # Uses current directory as target repo.
    if [[ -n "$input_a" && -z "$input_b" ]]; then
      phase="$input_a"
      repo_path="$(pwd -P)"
      repo="$(basename "$repo_path")"
    # Explicit mode: mesh run <repo-name|repo-path> <phase>
    elif [[ -n "$input_a" && -n "$input_b" ]]; then
      resolve_repo_path_and_name "$input_a"
      repo_path="$RESOLVED_REPO_PATH"
      repo="$RESOLVED_REPO_NAME"
      phase="$input_b"
    else
      usage
      exit 1
    fi

    thread_name="${repo}-spec-${phase}"
    feature="spec-${phase}"
    run_meshctl pipeline create \
      --template "$PIPELINE_TEMPLATE" \
      --thread-name "$thread_name" \
      --repo "$repo_path" \
      --project "$repo" \
      --feature "$feature" \
      --phase "$phase" \
      --account-scope repo
    echo "Started thread: $thread_name"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
