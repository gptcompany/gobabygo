# Shared worker/runtime settings for WS.
#
# Install to /etc/mesh-worker/common.env and keep this file outside git on live hosts.
# Instance-specific files under /etc/mesh-worker/*.env still define worker_id, cli,
# account profile, command, execution mode, and timeouts.

MESH_ROUTER_URL=http://192.168.1.100:8780
MESH_AUTH_TOKEN=__REPLACE_WITH_TOKEN__
MESH_ALLOWED_WORK_DIRS=/tmp/mesh-tasks,/media/sam/1TB
