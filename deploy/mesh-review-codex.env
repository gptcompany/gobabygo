MESH_ROUTER_URL=http://10.0.0.1:8780
MESH_AUTH_TOKEN=__REPLACE_WITH_TOKEN__

# Reviewer identity stored in verifier events payload.
MESH_REVIEWER_ID=review-codex

# CLI command template. Supports {account_profile}.
MESH_REVIEW_CLI_COMMAND=ccs codex --effort xhigh
MESH_ACCOUNT_PROFILE=review-codex

# Optional filters (empty = review every task in review state).
# MESH_REVIEW_TARGET_CLI=claude
# MESH_REVIEW_TARGET_ACCOUNT=work-claude

MESH_REVIEW_POLL_INTERVAL_S=8
MESH_REVIEW_MAX_TASKS=100
MESH_TASK_TIMEOUT_S=1200
MESH_WORK_DIR=/tmp/mesh-tasks
MESH_ALLOWED_WORK_DIRS=/tmp/mesh-tasks,/media/sam/1TB
MESH_DRY_RUN=1
