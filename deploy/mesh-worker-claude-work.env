MESH_WORKER_ID=ws-claude-work-01
MESH_ROUTER_URL=http://10.0.0.1:8780
MESH_CLI_TYPE=claude
MESH_ACCOUNT_PROFILE=work-claude
MESH_AUTH_TOKEN=__REPLACE_WITH_TOKEN__
MESH_LONGPOLL_TIMEOUT_S=25
MESH_CLI_COMMAND=ccs claude
# Required for native Claude Agent Teams (harmless for batch mode; needed for interactive session workers).
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
MESH_DRY_RUN=1
MESH_WORK_DIR=/tmp/mesh-tasks
MESH_ALLOWED_WORK_DIRS=/tmp/mesh-tasks,/media/sam/1TB
MESH_TASK_TIMEOUT_S=1800
