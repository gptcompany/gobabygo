# Shared defaults for interactive session workers on WS.
#
# Install to /etc/mesh-worker/mesh-session.common.env and keep it outside git on
# live hosts once customized.

MESH_HEARTBEAT_TIMEOUT_S=10
MESH_CONTROL_PLANE_TIMEOUT_S=60
MESH_LONGPOLL_TIMEOUT_S=25
MESH_EXECUTION_MODES=session
MESH_WORK_DIR=/tmp/mesh-tasks
MESH_TASK_TIMEOUT_S=7200
MESH_SESSION_POLL_INTERVAL_S=1.0
MESH_TMUX_SESSION_PREFIX=mesh
MESH_AUTO_COMPLETE_ON_EXIT=1
