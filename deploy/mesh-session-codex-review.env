MESH_WORKER_ID=ws-codex-review-01
MESH_ROUTER_URL=http://10.0.0.1:8780
MESH_CLI_TYPE=codex
MESH_ACCOUNT_PROFILE=review-codex
MESH_AUTH_TOKEN=__REPLACE_WITH_TOKEN__
MESH_HEARTBEAT_TIMEOUT_S=5
MESH_CONTROL_PLANE_TIMEOUT_S=30
MESH_LONGPOLL_TIMEOUT_S=25
