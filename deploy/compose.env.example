# External Docker Compose runtime config for production/live deploys.
#
# Recommended live path: /etc/mesh-router/compose.env
# Then run Docker Compose via deploy/live-compose.sh.

MESH_ROUTER_SUPERVISOR=docker
MESH_AUTH_TOKEN=__REPLACE_WITH_TOKEN__
MESH_MATRIX_ACCESS_TOKEN=__REPLACE_WITH_MATRIX_TOKEN__
MESH_ROUTER_BIND_HOST=0.0.0.0
MESH_MATRIX_BRIDGE_DOCKER_ENV_FILE=/etc/mesh-router/mesh-matrix-bridge.docker.env
MESH_MATRIX_BRIDGE_CONFIG_DIR=/etc/mesh-router/config
