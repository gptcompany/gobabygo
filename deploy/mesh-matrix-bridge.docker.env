# Matrix bridge configuration for Docker Compose.
# Required secrets are injected from shell env:
# - MESH_AUTH_TOKEN
# - MESH_MATRIX_ACCESS_TOKEN

MESH_MATRIX_HOMESERVER=https://matrix.princyx.xyz
MESH_MATRIX_DEFAULT_ROOM=!default:matrix.princyx.xyz
MESH_MATRIX_UNROUTED_ROOM=!unrouted:matrix.princyx.xyz

# Optional
MESH_MATRIX_POLL_INTERVAL_S=10
MESH_MATRIX_BOSS_ROOM=!boss:matrix.princyx.xyz
# MESH_MATRIX_INPUT_PATTERNS=approve|continue|press enter|y/n|select|confirm|proceed
# MESH_MATRIX_REQUEST_TIMEOUT_S=10
# MESH_TOPOLOGY_PATH=/app/deploy/topology.v1.4.example.yml
