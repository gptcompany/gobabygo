MESH_WORKER_ID=ws-gemini-session-dyn-01
MESH_ROUTER_URL=http://192.168.1.100:8780
MESH_CLI_TYPE=gemini
MESH_ACCOUNT_PROFILE=work-gemini-sess
MESH_AUTH_TOKEN=__REPLACE_WITH_TOKEN__
MESH_HEARTBEAT_TIMEOUT_S=5
MESH_CONTROL_PLANE_TIMEOUT_S=30
MESH_LONGPOLL_TIMEOUT_S=25
MESH_CLI_COMMAND=ccs {target_account}
MESH_EXECUTION_MODES=session
MESH_WORK_DIR=/tmp/mesh-tasks
MESH_ALLOWED_WORK_DIRS=/tmp/mesh-tasks,/media/sam/1TB
MESH_TASK_TIMEOUT_S=7200
MESH_SESSION_POLL_INTERVAL_S=1.0
MESH_TMUX_SESSION_PREFIX=mesh
MESH_AUTO_COMPLETE_ON_EXIT=1
PATH=/home/sam/.npm-global/bin:/usr/local/bin:/usr/bin:/bin
MESH_ALLOWED_ACCOUNTS=*
MESH_UPTERM_BIN=/usr/bin/upterm
