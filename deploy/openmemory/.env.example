# OpenMemory environment variables
# Copy to .env and fill in values. Use dotenvx for encryption.
#
# Usage: dotenvx run -f .env -- docker compose up -d --build

# --- Auth (required) ---
OM_API_KEY=changeme-generate-a-random-key

# --- Embedding Provider ---
# Options: openai, gemini, ollama, local, synthetic
OM_EMBEDDINGS=ollama
OM_EMBEDDING_FALLBACK=synthetic
OLLAMA_URL=http://host.docker.internal:11434

# Optional: OpenAI as primary or fallback
# OPENAI_API_KEY=sk-...

# --- Server (defaults, usually no change needed) ---
# OM_PORT=8080
# OM_DB_PATH=/data/openmemory.db
# OM_MODE=production
# OM_TIER=hybrid
