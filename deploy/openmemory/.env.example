# OpenMemory environment variables
# Copy to .env and fill in values. Use dotenvx for encryption.
#
# Usage: dotenvx run -f .env -- docker compose up -d --build

# --- Embedding Provider (primary: Ollama, fallback: OpenAI) ---
OM_EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Optional: OpenAI fallback (leave empty to disable)
# OPENAI_API_KEY=sk-...

# --- Server ---
# OM_PORT=8080           # default
# OM_DB_PATH=/data/openmemory.db  # default, inside Docker volume
# OM_MODE=production     # default
