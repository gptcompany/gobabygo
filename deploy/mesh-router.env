MESH_ROUTER_SUPERVISOR=systemd
MESH_ROUTER_PORT=8780
MESH_DB_PATH=/var/lib/mesh-router/router.db
MESH_BUFFER_PATH=/var/lib/mesh-router/events-buffer.jsonl
MESH_AUTH_TOKEN=__REPLACE_WITH_TOKEN__
MESH_DEV_MODE=1
MESH_DISPATCH_INTERVAL_S=5
MESH_LONGPOLL_TIMEOUT_S=25

# Session-first policy (recommended for interactive workflows)
MESH_DEFAULT_EXECUTION_MODE=session
MESH_SESSION_FALLBACK_TO_BATCH=0
MESH_ENFORCE_SESSION_ONLY=1
